{
  "manifest_version": 3,
  "name": "MJ 크롤링 매니저 실행기",
  "version": "1.0.0",
  "description": "Chrome 툴바 아이콘 클릭으로 MJ 크롤링 매니저 서버 실행 + 자동 탭 열기",
  "action": {
    "default_title": "MJ 크롤링 매니저 실행"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["nativeMessaging", "tabs"]
}
